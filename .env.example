# Copy this file to .env and adjust values for your environment.
# API base URL. Keep localhost for local development, or set your production API domain.
VITE_API_BASE_URL=http://localhost:4000

# Public base URL used for absolute links in emails/notifications when window origin is unavailable.
VITE_APP_BASE_URL=https://your-site-domain.com

# Seed admin credentials for local/demo mode.
# For production builds, set explicit values (no unsafe fallback credentials are used).
VITE_SEED_ADMIN_EMAIL=admin@example.com
VITE_SEED_ADMIN_PASSWORD=change_me_admin
VITE_SEED_DEMO_PASSWORD=demo123

# Optional hardening toggles:
# Keep alias logins disabled in production unless you intentionally need them.
# VITE_ENABLE_LOGIN_ALIASES=false
# Force frontend login to require API auth even outside production.
# VITE_REQUIRE_BACKEND_AUTH=true
# Prevent automatic localStorage wipe on schema version changes in production.
# Set true only for controlled migrations.
# VITE_ENABLE_PROD_DATA_MIGRATION_RESET=false
