# Snippet for nginx on the server that serves `dist/` (Vite build).
# Problem: if `index.html` is cached, users keep loading OLD hashed JS filenames from a previous deploy.
# Fix: never long-cache the HTML shell; hashed `/assets/*` can stay immutable.

server {
  # ... your listen, server_name, ssl, root ...

  # Long cache for fingerprinted assets (Vite adds hashes to filenames).
  location /assets/ {
    add_header Cache-Control "public, max-age=31536000, immutable";
    try_files $uri =404;
  }

  # Do not cache the HTML document (SPA entry).
  location = /index.html {
    add_header Cache-Control "no-store, no-cache, must-revalidate, max-age=0" always;
    try_files $uri =404;
  }

  # SPA fallback — same no-cache as index.html if you use try_files ... /index.html
  location / {
    add_header Cache-Control "no-store, no-cache, must-revalidate, max-age=0" always;
    try_files $uri $uri/ /index.html;
  }
}
